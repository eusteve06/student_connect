# Copy to .env and fill in real values. Do NOT commit .env (it is gitignored).

# Port the API listens on. Keep in sync with the frontend's VITE_API_BASE_URL.
PORT=5000

NODE_ENV=development

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# PostgreSQL connection string.
#   - Leave UNSET to use the in-memory pg-mem database (seeded from sql/*.sql).
#   - Set it to connect to a real PostgreSQL server. For a hosted DB (e.g. Render)
#     use the EXTERNAL connection string when connecting from outside its network.
#     Apply sql/schema.sql + sql/seed.sql + sql/migrate_admins.sql to it once.
# DATABASE_URL=postgresql://user:password@host:5432/student_connectdb
